# ── LLM ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Authentication ───────────────────────────────────
JWT_SECRET_KEY=change-this-in-local-env

# ── LangSmith Studio ─────────────────────────────────
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=cen-interview-backend
# ── Notion MCP ───────────────────────────────────────
# 인덱싱 파이프라인이 Notion 페이지를 읽을 때 사용
NOTION_MCP_URL=https://mcp.notion.com/mcp
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/api/auth/notion/callback
NOTION_MCP_ACCESS_TOKEN=
FRONTEND_APP_URL=http://localhost:5173

# ── GitHub MCP ───────────────────────────────────────
# 프로젝트 저장소 제한없이 접근
GITHUB_TOKEN=ghp_...
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/github/callback
GITHUB_OAUTH_SCOPE=read:user repo

# ── Vector DB (Postgres + pgvector) ───────────────────
DATABASE_URL=postgresql+psycopg://interview:1234@localhost:5432/interviewdb
# 운영 환경은 Alembic migration을 먼저 적용하므로 false로 설정
DATABASE_AUTO_CREATE_TABLES=false

# ── Embedding ─────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
QUESTION_PATTERN_MIN_SIMILARITY=0.30
# 로컬 직접 실행 기본값은 ../data, Docker 운영 환경은 /app/data 권장
QUESTION_PATTERN_DATA_PATH=../data
EVIDENCE_STORE_BACKEND=pgvector
EVIDENCE_LLM_EXTRACT_ENABLED=true
EVIDENCE_GITHUB_MAX_COMMITS=200
# 0이면 지원하는 모든 소스 파일을 수집합니다.
EVIDENCE_GITHUB_MAX_CODE_FILES=0
EVIDENCE_GITHUB_MAX_FILE_CHARS=100000
EVIDENCE_GITHUB_MAX_DIRS=500
EVIDENCE_GITHUB_MAX_DEPTH=15
EVIDENCE_LLM_CONCURRENCY=4
EVIDENCE_MCP_CONCURRENCY=3
EVIDENCE_MCP_MAX_ATTEMPTS=3
EVIDENCE_MCP_RETRY_BASE_SECONDS=2.0
EVIDENCE_EMBEDDING_BATCH_SIZE=128
EVIDENCE_EMBEDDING_CONCURRENCY=2
EVIDENCE_DB_BATCH_SIZE=500

# ── App ──────────────────────────────────────────────
LLM_MODEL=gpt-5.4-mini
LLM_LOG_ENABLED=true
# true로 바꾸면 프롬프트와 사용자 답변 등 LLM 입력도 로그에 포함됩니다.
LLM_LOG_INCLUDE_INPUT=false
LLM_LOG_MAX_LENGTH=5000
TURN_COMPLETION_CONFIRM_CONFIDENCE=0.7
TURN_CONFIRMATION_PAUSE_SECONDS=0.8
TURN_CONFIRMATION_READY_TIMEOUT_SECONDS=15.0
TURN_CONFIRMATION_RESPONSE_TIMEOUT_SECONDS=8.0
TURN_COMPLETION_AUTO_SUBMIT_CONFIDENCE=0.85
TURN_COMMIT_GRACE_MILLISECONDS=300
MAX_QUESTIONS=10
VOICE_TURN_AUTH_TIMEOUT_SECONDS=5.0
