# ── LLM ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Notion MCP ───────────────────────────────────────
# 인덱싱 파이프라인이 Notion 페이지를 읽을 때 사용
NOTION_API_KEY=secret_...

# ── GitHub MCP ───────────────────────────────────────
# 프로젝트 저장소(최대 3개) 접근에 사용
GITHUB_TOKEN=ghp_...

# ── Vector DB (Postgres + pgvector) ───────────────────
DATABASE_URL=postgresql+psycopg://interview:1234@localhost:5432/interviewdb

# ── App ──────────────────────────────────────────────
LLM_MODEL=gpt-5.4-mini
MAX_QUESTIONS=10
