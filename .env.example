# ── LLM ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Notion MCP ───────────────────────────────────────
# 인덱싱 파이프라인이 Notion 페이지를 읽을 때 사용
NOTION_API_KEY=secret_...

# ── GitHub MCP ───────────────────────────────────────
# 프로젝트 저장소(최대 3개) 접근에 사용
GITHUB_TOKEN=ghp_...

# ── Vector DB ────────────────────────────────────────
# chromadb 로컬 저장 경로
EVIDENCE_STORE_PATH=./.evidence_store

# ── App ──────────────────────────────────────────────
LLM_MODEL=claude-sonnet-4-6
MAX_QUESTIONS=10
